# ProjectLens local environment

# Postgres
PROJECTLENS_DATABASE_URL=postgres://projectlens:projectlens@localhost:5433/projectlens?sslmode=disable
PROJECTLENS_DB_PASSWORD=projectlens
PROJECTLENS_DB_PORT=5433

# MCP server
PROJECTLENS_MCP_PORT=8484

# Target repo (absolute path; default is this repo)
PROJECTLENS_REPO_PATH=.

# Ollama
PROJECTLENS_OLLAMA_ENDPOINT=http://localhost:11434

# TUI run logs (optional)
# PROJECTLENS_TUI_RUNS_DIR=~/.projectlens/tui-runs
# PROJECTLENS_TUI_LOG_FILE=~/.projectlens/tui.log
