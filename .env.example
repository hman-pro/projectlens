# ProjectLens environment template.
# Copy to .env (already gitignored) and edit. Loaded automatically by the
# projectlens and projectlens-mcp binaries on startup. Explicit shell exports
# and CLI flags override values here.

# ---- Binary runtime (read by the Go process) ----------------------------

# Postgres connection string used by all CLI commands and the MCP server.
DATABASE_URL=postgres://projectlens:projectlens@localhost:5433/projectlens?sslmode=disable

# Path to the target repository being indexed.
REPO_PATH=/Users/you/source/your-repo

# Anthropic API key — required when summarization.provider=anthropic (default).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key — required only when an OpenAI provider is selected.
OPENAI_API_KEY=sk-your-key-here

# Ollama endpoint for local embeddings (override config default).
# OLLAMA_ENDPOINT=http://localhost:11434

# MCP server port (read only by projectlens-mcp).
# MCP_PORT=8484

# Path to YAML config file (overrides default configs/index.yaml).
# CONFIG_PATH=configs/index.yaml

# ---- Docker Compose substitution (read by docker-compose.yml) -----------

# Host path mounted read-only into the indexer/MCP containers.
PROJECTLENS_REPO_PATH=/Users/you/source/your-repo

# Postgres password and host port mapping for the compose stack.
PROJECTLENS_DB_PASSWORD=projectlens
PROJECTLENS_DB_PORT=5433

# MCP server host port mapping for the compose stack.
PROJECTLENS_MCP_PORT=8484
